webkit-scrollbar { display: none !important; width: 0px !important; }\r\n        body, html { scrollbar-width: none !important; padding: 0 !important; margin: 0 !important; }\r\n    `;\r\n\r\n    // CSS'i anında enjekte et\r\n    var style = document.createElement('style');\r\n    style.innerHTML = css;\r\n    (document.head || document.documentElement).appendChild(style);\r\n\r\n    // Dinamik kontrol (Yeni öğeler yüklenirse tekrar gizle)\r\n    var observer = new MutationObserver(function() {\r\n        var targets = ['.breadcrumb', '.halo-breadcrumb', 'footer'];\r\n        targets.forEach(function(t) {\r\n            var el = document.querySelector(t);\r\n            if (el) el.style.display = 'none';\r\n        });\r\n    });\r\n\r\n    observer.observe(document.documentElement, { childList: true, subtree: true });\r\n})();","webUrl":"https://custompremiumshirt.com/collections/banners","buttons":[],"category":"gid://shopify/Collection/481792721120","enableClose":true,"webViewMode":true,"bannerHeight":15,"useTabScreen":false,"enableDivider":false,"enableForward":true,"requiredLogin":false,"enableBackward":true,"iconFontFamily":"CupertinoIcons","buttonAlignment":"centerLeft"},"web-QIEXUXJjzx":{"id":"web-12","icon":"pencil","title":"Print on Demand","screen":"category","script":"(function() {\r\n    // 1. Web sitesinin yapısal boşluklarını hedef alan CSS\r\n    var css = `\r\n        /* Bölümler (Sections) arasındaki tüm yapısal boşlukları daralt */\r\n        .shopify-section, \r\n        [id^=\"shopify-section\"],\r\n        .section-wrapper,\r\n        .container {\r\n            margin-top: 0px !important;\r\n            margin-bottom: 5px !important; /* Üstteki küçük boşlukla eşitlemek için */\r\n            padding-top: 0px !important;\r\n            padding-bottom: 0px !important;\r\n        }\r\n\r\n        /* En altta kalan dev beyazlığı (Footer alanını) fiziksel olarak yok et */\r\n        footer, .site-footer, [id*=\"footer\"], .halo-popup, .auth-actions